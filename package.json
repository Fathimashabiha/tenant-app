{
    "name":  "sz-tenant-mobileapp",
    "version":  "1.0.0",
    "description":  "SpaceZen Tenant Mobile App",
    "main":  "index.ts",
    "scripts":  {
                    "dev":  "expo start --dev-client",
                    "start":  "expo start",
                    "prebuild":  "expo prebuild",
                    "prebuild:clean":  "expo prebuild --clean",
                    "build:android:dev":  "eas build --platform android --profile preview",
                    "build:android:eas":  "eas build --platform android --profile production",
                    "build:ios:dev":  "eas build --platform ios --profile preview",
                    "build:ios:eas":  "eas build --platform ios --profile production"
                },
    "dependencies":  {
                         "expo":  "^52.0.0",
                         "expo-av":  "^14.0.0",
                         "expo-font":  "^12.0.0",
                         "expo-image-picker":  "^15.0.0",
                         "expo-dev-client":  "^3.0.0",
                         "react":  "^19.0.0-rc-66855b96-20241106",
                         "react-native":  "^0.76.0-rc.5",
                         "react-native-gesture-handler":  "^2.14.0",
                         "react-native-reanimated":  "^3.8.0",
                         "react-native-safe-area-context":  "^4.8.0",
                         "react-native-screens":  "^3.27.0",
                         "@react-navigation/native":  "^6.1.0",
                         "@react-navigation/bottom-tabs":  "^6.5.0",
                         "@react-navigation/stack":  "^6.3.0",
                         "axios":  "^1.6.0",
                         "zustand":  "^4.5.0"
                     },
    "devDependencies":  {
                            "typescript":  "^5.9.0",
                            "@types/react":  "^19.0.0-rc.0",
                            "@types/react-native":  "^0.73.0",
                            "expo-cli":  "^6.0.0"
                        }
}
